/* 全局重置 */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffecd2 0%, #fcb69f 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15px;
  padding-bottom: 30px;
}

/* 顶部区域 */
.header {
  padding: 25px 20px 15px;
  text-align: center;
  background: linear-gradient(180deg, #fff8f5 0%, #fff 100%);
  width: 100%;
  max-width: 420px;
  border-radius: 40px 40px 0 0;
}

.bunny {
  font-size: 64px;
  display: block;
  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.1));
}

.title {
  font-size: 24px;
  font-weight: 800;
  color: #ff9a9e;
  margin-top: 5px;
  display: block;
}

/* 节拍指示器 */
.beats-section {
  width: 100%;
  max-width: 420px;
  padding: 15px;
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
  min-height: 90px;
  align-items: center;
  background: #fff;
}

.beat {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 800;
  color: #fff;
  transition: transform 0.1s;
}

.beat.uniform {
  background: #a8edea;
  box-shadow: 0 4px 12px rgba(168, 237, 234, 0.5);
}

.beat.strong {
  background: #ff6b6b;
  width: 64px;
  height: 64px;
  font-size: 24px;
  box-shadow: 0 5px 18px rgba(255, 107, 107, 0.5);
}

.beat.traditional {
  background: #a8edea;
  box-shadow: 0 4px 12px rgba(168, 237, 234, 0.5);
}

.beat.voice {
  background: #ffd93d;
  box-shadow: 0 4px 12px rgba(255, 217, 61, 0.5);
}

.beat.pop {
  transform: scale(1.3);
}

/* BPM 区域 */
.bpm-display {
  text-align: center;
  background: #fff;
  width: 100%;
  max-width: 420px;
  padding: 10px 25px 5px;
}

.bpm-val {
  font-size: 58px;
  font-weight: 900;
  color: #74b9ff;
  display: block;
}

.bpm-unit {
  font-size: 13px;
  color: #a29bfe;
  font-weight: 700;
  display: block;
}

/* 滑块 */
.slider-wrap {
  width: 100%;
  max-width: 420px;
  padding: 0 20px 15px;
  background: #fff;
}

.slider-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.bpm-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: none;
  font-size: 26px;
  font-weight: 700;
  cursor: pointer;
  background: #ffeaa7;
  color: #e17055;
  box-shadow: 0 4px 12px rgba(255, 217, 61, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.bpm-btn.sm {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  font-size: 18px;
  font-weight: 700;
  background: #ffeaa7;
  color: #e17055;
  box-shadow: 0 4px 12px rgba(255, 217, 61, 0.4);
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
}

slider {
  width: 100%;
}

/* 播放按钮 */
.control {
  width: 100%;
  max-width: 420px;
  padding: 10px 25px 25px;
  display: flex;
  justify-content: center;
  background: #fff;
}

.play-btn {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: none;
  font-size: 36px;
  cursor: pointer;
  background: #55efc4;
  color: #fff;
  box-shadow: 0 8px 25px rgba(0, 184, 148, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn.running {
  background: #ff6b6b;
  box-shadow: 0 8px 25px rgba(255, 107, 107, 0.4);
}

/* 设置面板 */
.settings {
  width: 100%;
  max-width: 420px;
  background: linear-gradient(135deg, #fff8f5, #fffaf8);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(252, 147, 127, 0.08);
  margin-top: 8px;
}

.toggle {
  width: 100%;
  padding: 16px 18px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: none;
  cursor: pointer;
  font-size: 14px;
  font-weight: 700;
  color: #ff9a9e;
  background: transparent;
  transition: background 0.2s;
  text-align: left;
}

.toggle-arrow {
  font-size: 11px;
  background: rgba(255, 154, 158, 0.12);
  border-radius: 50%;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s;
}

.toggle.open .toggle-arrow {
  transform: rotate(180deg);
}

.panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.panel.open {
  max-height: 1400px;
}

.panel-inner {
  padding: 15px 20px 30px;
  border-top: 1px solid rgba(252, 147, 127, 0.1);
}

.section-title {
  font-size: 11px;
  font-weight: 700;
  color: #b2bec3;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 10px;
}

/* 音效模式按钮 */
.mode-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.mode-btn {
  flex: 1;
  padding: 10px 6px;
  border-radius: 12px;
  background: #f8f9fa;
  border: 2px solid transparent;
  cursor: pointer;
  text-align: center;
  font-size: 12px;
  font-weight: 700;
  color: #666;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mode-btn.active {
  background: linear-gradient(135deg, #a8edea, #7dd3d0);
  color: #fff;
}

.mode-icon {
  font-size: 24px;
  margin-bottom: 4px;
  display: block;
}

/* 节拍预设 */
.time-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.time-btn {
  padding: 10px 8px;
  border-radius: 12px;
  background: #f8f9fa;
  border: 2px solid transparent;
  cursor: pointer;
  text-align: center;
  font-weight: 800;
  font-size: 15px;
  color: #333;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 58px;
}

.time-btn.active {
  background: linear-gradient(135deg, #ffeaa7, #ffd93d);
  border-color: transparent;
  color: #e17055;
}

.time-label {
  display: block;
  font-size: 11px;
  font-weight: 500;
  opacity: 0.7;
  margin-top: 3px;
}

/* 自定义节拍 */
.custom-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}

.custom-input {
  width: 55px;
  height: 42px;
  border: 2px solid #eee;
  border-radius: 10px;
  text-align: center;
  font-size: 18px;
  font-weight: 700;
  color: #333;
  background: #fff;
}

.custom-sep {
  font-size: 22px;
  font-weight: 700;
  color: #ccc;
}

.apply-btn {
  padding: 10px 18px;
  background: linear-gradient(135deg, #ff9a9e, #ff6b6b);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
}
